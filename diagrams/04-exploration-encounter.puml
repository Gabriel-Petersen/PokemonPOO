@startuml exploration_encounter
skinparam style strictuml
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor #F8FAFC
    BorderColor #64748B
    FontColor #0F172A
}

skinparam class<<abstract>> {
    BackgroundColor #FFF7ED
    BorderColor #C2410C
    FontColor #9A3412
}

skinparam class<<interface>> {
    BackgroundColor #ECFEFF
    BorderColor #0F766E
    FontColor #115E59
}

skinparam class<<enum>> {
    BackgroundColor #EEF2FF
    BorderColor #4338CA
    FontColor #312E81
}

package "domain.exploration" {
    enum EncounterKind <<enum>> #EEF2FF {
        WILD
        NPC
    }

    class EncounterZone #F8FAFC {
        -name: String
        -isCaptureArea: Boolean
        -rollIntervalSeconds: Double
        -wildTrigger: WildEncounterTrigger
        -npcTriggers: List<NpcEncounterTrigger>
        +contains(tileX: Integer, tileY: Integer) Boolean
        +supportsWildEncounter() Boolean
        +supportsNpcEncounter() Boolean
    }

    class EncounterTable #F8FAFC {
        -entries: List<EncounterEntry>
        +rollWildEntry() EncounterEntry
        +hasEntries() Boolean
    }

    class EncounterEntry #F8FAFC {
        -species: Species
        -minLevel: Integer
        -maxLevel: Integer
        -encounterChance: Double
        +matchesRoll(roll: Double) Boolean
        +rollLevel() Integer
    }

    interface EncounterTrigger <<interface>> #ECFEFF {
        +canTrigger(player: PlayerTrainer, context: ExplorationContext) Boolean
        +createBattle(player: PlayerTrainer) Battle
        +getKind() EncounterKind
    }

    class WildEncounterTrigger #F8FAFC {
        -table: EncounterTable
        -wildTrainer: WildTrainer
        -rollIntervalSeconds: Double
        -elapsedSeconds: Double
        -timerActive: Boolean
        +canTrigger(player: PlayerTrainer, context: ExplorationContext) Boolean
        +createBattle(player: PlayerTrainer) Battle
        +getKind() EncounterKind
        +accumulate(deltaTime: Double) void
        +shouldRoll() Boolean
        +stopTimer() void
        +resumeTimer() void
    }

    class NpcEncounterTrigger #F8FAFC {
        -trainer: NpcTrainer
        -engaged: Boolean
        +canTrigger(player: PlayerTrainer, context: ExplorationContext) Boolean
        +createBattle(player: PlayerTrainer) Battle
        +getKind() EncounterKind
    }

    class ExplorationContext #F8FAFC {
        -tileX: Integer
        -tileY: Integer
        -deltaTime: Double
        -isMoving: Boolean
        +isInside(zone: EncounterZone) Boolean
    }

    class EncounterService #F8FAFC {
        -currentZone: EncounterZone
        -battleRunning: Boolean
        +update(player: PlayerTrainer, context: ExplorationContext) Battle
        +startEncounterBattle(trigger: EncounterTrigger, player: PlayerTrainer) Battle
        +pauseEncounterTimers() void
        +resumeEncounterTimers() void
    }
}

package "domain.shared" {
    class Species #F8FAFC
    class PlayerTrainer #F8FAFC
    class NpcTrainer #F8FAFC
    class WildTrainer #F8FAFC
    class Battle #F8FAFC
}

EncounterZone *-- EncounterTable
EncounterZone *-- WildEncounterTrigger
EncounterZone o-- "0..*" NpcEncounterTrigger
EncounterTable *-- "1..*" EncounterEntry
EncounterEntry --> Species

EncounterTrigger <|.. WildEncounterTrigger
EncounterTrigger <|.. NpcEncounterTrigger

WildEncounterTrigger --> EncounterTable
WildEncounterTrigger --> WildTrainer
NpcEncounterTrigger --> NpcTrainer

EncounterService --> EncounterZone
EncounterService --> EncounterTrigger
EncounterService --> ExplorationContext
EncounterService --> Battle

EncounterTrigger --> EncounterKind

note right of EncounterService
If player is inside a capture area,
the wild timer keeps accumulating and
rolls encounter chance every interval,
even while standing still.
When battle starts, timer pauses.
end note

@enduml
